{
  "manifest_version": 3,
  "name": "ほやほやほんやく",
  "version": "0.1.0",
  "description": "ブラウザ上のテキストを「ほや語」に変換するほやドル公認拡張機能",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ほやほやほんやく",
    "default_icon": {
      "16": "icons/mode1_16.png",
      "48": "icons/mode1_48.png",
      "128": "icons/mode1_128.png"
    }
  },
  "icons": {
    "16": "icons/mode1_16.png",
    "48": "icons/mode1_48.png",
    "128": "icons/mode1_128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
